<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <!-- Include user preferences and settings -->
        <include domain="sharedpref" path="app_settings.xml"/>
        <include domain="sharedpref" path="app_migration.xml"/>

        <!-- Include user's task database -->
        <include domain="database" path="task_database"/>
        <include domain="database" path="task_database-shm"/>
        <include domain="database" path="task_database-wal"/>

        <!-- Exclude cache and temporary files -->
        <exclude domain="cache" path="."/>
        <exclude domain="external" path="."/>

        <!-- Exclude device-specific data -->
        <exclude domain="sharedpref" path="device_specific.xml"/>
    </cloud-backup>

    <device-transfer>
        <!-- Include all user data for device transfer -->
        <include domain="sharedpref" path="app_settings.xml"/>
        <include domain="sharedpref" path="app_migration.xml"/>
        <include domain="database" path="task_database"/>
        <include domain="database" path="task_database-shm"/>
        <include domain="database" path="task_database-wal"/>

        <!-- Exclude temporary and cache data -->
        <exclude domain="cache" path="."/>
        <exclude domain="external" path="."/>
    </device-transfer>
</data-extraction-rules>