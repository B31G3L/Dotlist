<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF" />
            <corners android:radius="16dp" />
            <stroke
                android:width="2dp"
                android:color="#E0E0E0" />
        </shape>
    </item>

    <!-- Content Preview -->
    <item
        android:left="16dp"
        android:top="16dp"
        android:right="16dp"
        android:bottom="16dp">
        <vector
            android:width="108dp"
            android:height="108dp"
            android:viewportWidth="108"
            android:viewportHeight="108">

            <!-- App Title -->
            <group android:translateX="20" android:translateY="15">
                <path
                    android:fillColor="#3C3C3C"
                    android:pathData="M0,0 L60,0 L60,8 L0,8 Z" />
            </group>

            <!-- Progress Text -->
            <group android:translateX="20" android:translateY="30">
                <path
                    android:fillColor="#009966"
                    android:pathData="M0,0 L40,0 L40,6 L0,6 Z" />
            </group>

            <!-- Task 1 (Completed) -->
            <group android:translateX="20" android:translateY="45">
                <!-- Checkbox checked -->
                <path
                    android:fillColor="#009966"
                    android:pathData="M0,0 L8,0 L8,8 L0,8 Z" />
                <!-- Task text -->
                <path
                    android:fillColor="#3C3C3C"
                    android:pathData="M12,0 L50,0 L50,5 L12,5 Z" />
            </group>

            <!-- Task 2 (Pending) -->
            <group android:translateX="20" android:translateY="60">
                <!-- Checkbox unchecked -->
                <path
                    android:fillColor="@android:color/transparent"
                    android:strokeColor="#009966"
                    android:strokeWidth="1"
                    android:pathData="M0,0 L8,0 L8,8 L0,8 Z" />
                <!-- Task text -->
                <path
                    android:fillColor="#3C3C3C"
                    android:pathData="M12,0 L55,0 L55,5 L12,5 Z" />
            </group>

            <!-- More indicator -->
            <group android:translateX="20" android:translateY="75">
                <path
                    android:fillColor="#666666"
                    android:pathData="M0,0 L35,0 L35,4 L0,4 Z" />
            </group>
        </vector>
    </item>
</layer-list>
