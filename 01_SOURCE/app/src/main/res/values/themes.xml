<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DailyList" parent="android:Theme.Material.Light.NoActionBar">
        <!-- Primary colors -->
        <item name="android:colorPrimary">@color/app_green</item>
        <item name="android:colorPrimaryDark">@color/app_green_dark</item>
        <item name="android:colorAccent">@color/app_green_light</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">true</item>

        <!-- Window properties -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>

    <!-- Dark theme -->
    <style name="Theme.DailyList.Dark" parent="android:Theme.Material.NoActionBar">
        <!-- Primary colors -->
        <item name="android:colorPrimary">@color/app_green</item>
        <item name="android:colorPrimaryDark">@color/app_green_dark</item>
        <item name="android:colorAccent">@color/app_green_light</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightNavigationBar">false</item>

        <!-- Window properties -->
        <item name="android:windowDrawsSystemBarBackgrounds">true</item>
        <item name="android:windowTranslucentStatus">false</item>
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>
        <item name="android:enforceStatusBarContrast">false</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.DailyList.Splash" parent="Theme.SplashScreen">
        <item name="android:windowSplashScreenBackground">@color/app_green</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenIconSize">144dp</item>
        <item name="android:windowSplashScreenBrandingImage">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.DailyList</item>
    </style>
</resources>