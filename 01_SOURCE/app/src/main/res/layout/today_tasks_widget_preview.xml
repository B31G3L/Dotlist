<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Heute"
            android:textSize="16sp"
            android:textColor="@color/app_green"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2/5"
            android:textSize="12sp"
            android:textColor="@color/app_medium_gray" />

    </LinearLayout>

    <!-- Progress Bar -->
    <ProgressBar
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:progress="40"
        android:progressTint="@color/app_green"
        android:progressBackgroundTint="@color/app_green"
        android:alpha="0.3"
        android:layout_marginBottom="12dp" />

    <!-- Sample Tasks -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Task 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <View
                android:layout_width="3dp"
                android:layout_height="16dp"
                android:background="@color/priority_high"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☑"
                android:textSize="14sp"
                android:textColor="@color/app_green"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="E-Mails bearbeiten"
                android:textSize="13sp"
                android:textColor="@color/app_medium_gray" />

        </LinearLayout>

        <!-- Task 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <View
                android:layout_width="3dp"
                android:layout_height="16dp"
                android:background="@color/priority_medium"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☐"
                android:textSize="14sp"
                android:textColor="@color/app_medium_gray"
                android:layout_marginEnd="8dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Projekt fertigstellen"
                android:textSize="13sp"
                android:textColor="@color/app_dark_gray" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>