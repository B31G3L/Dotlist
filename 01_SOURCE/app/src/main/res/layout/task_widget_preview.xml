<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily List"
        android:textColor="@color/app_dark_gray"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal" />

    <!-- Progress -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="2 von 5 (40%)"
        android:textColor="@color/app_green"
        android:textSize="12sp"
        android:layout_gravity="center_horizontal" />

    <!-- Progress Bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="8dp"
        android:background="@color/app_green"
        android:alpha="0.3" />

    <!-- Task List Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <!-- Task 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✓"
                android:textColor="@color/app_green"
                android:textSize="14sp" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/priority_medium" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="E-Mails beantworten"
                android:textColor="@color/app_dark_gray"
                android:textSize="11sp"
                android:alpha="0.7"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Task 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◯"
                android:textColor="@color/app_medium_gray"
                android:textSize="14sp" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/priority_high" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Präsentation vorbereiten"
                android:textColor="@color/app_dark_gray"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- Task 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="◯"
                android:textColor="@color/app_medium_gray"
                android:textSize="14sp" />

            <View
                android:layout_width="6dp"
                android:layout_height="6dp"
                android:layout_marginHorizontal="8dp"
                android:background="@color/priority_low" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Bericht schreiben"
                android:textColor="@color/app_dark_gray"
                android:textSize="11sp"
                android:maxLines="1" />
        </LinearLayout>

        <!-- More indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="und 2 weitere..."
            android:textColor="@color/app_medium_gray"
            android:textSize="10sp"
            android:alpha="0.7"
            android:layout_gravity="center_horizontal" />

    </LinearLayout>

</LinearLayout>