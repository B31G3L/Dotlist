<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Daily List"
        android:textColor="#3C3C3C"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Progress -->
    <TextView
        android:id="@+id/widget_progress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="3 von 5 Aufgaben"
        android:textColor="#009966"
        android:textSize="14sp" />

    <!-- Task List Container -->
    <LinearLayout
        android:id="@+id/widget_task_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <!-- Task 1 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/checkbox_checked" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="E-Mails beantworten"
                android:textColor="#3C3C3C"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Task 2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/checkbox_unchecked" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Präsentation vorbereiten"
                android:textColor="#3C3C3C"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Task 3 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingVertical="4dp">

            <View
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/checkbox_unchecked" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Bericht schreiben"
                android:textColor="#3C3C3C"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- More indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="24dp"
            android:text="und 2 weitere..."
            android:textColor="#666666"
            android:textSize="10sp" />

    </LinearLayout>

</LinearLayout>